{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECSRunAndPoll",
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask",
        "ecs:DescribeTaskDefinition",
        "ecs:DescribeTasks",
        "ecs:ListTasks",
        "ecs:StopTask"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassTaskRolesToECS",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::214443970313:role/fe-worker-ecs-task",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    }
  ]
}
